{
  "expo": {
    "name": "TimeMatrix",
    "slug": "vault-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Vault needs access to your photo library to import photos and videos into your secure vault.",
        "NSPhotoLibraryAddUsageDescription": "Vault needs access to save photos to your library."
      }
    },
    "android": {
      "statusBar": {
        "translucent": false,
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vault needs access to your photo library to import media into your secure vault."
        }
      ],
      "expo-asset",
      ["expo-media-library", { "isAccessMediaLocationEnabled": true }],
      "expo-video"
    ]
  }
}
